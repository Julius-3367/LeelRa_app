# Database
DATABASE_URL="postgresql://username:password@localhost:5432/leelra_db"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-nextauth-key-minimum-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# JWT
JWT_SECRET="your-jwt-secret-key-minimum-32-chars"
JWT_EXPIRES_IN="24h"
REFRESH_TOKEN_EXPIRES_IN="7d"

# SendGrid Email
SENDGRID_API_KEY="SG.your-sendgrid-api-key"
EMAIL_FROM="noreply@leelra.ke"
EMAIL_FROM_NAME="LeelRa App"

# Firebase FCM (JSON stringified service account)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project-id"}'

# Cloudinary
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
CLOUDINARY_URL="cloudinary://your-api-key:your-api-secret@your-cloud-name"

# Pusher (Real-time)
PUSHER_APP_ID="your-pusher-app-id"
PUSHER_KEY="your-pusher-key"
PUSHER_SECRET="your-pusher-secret"
PUSHER_CLUSTER="eu"
NEXT_PUBLIC_PUSHER_KEY="your-pusher-key"
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Redis (for rate limiting)
REDIS_URL="redis://localhost:6379"
